# --- DATABASE ---
DATABASE_URL="file:./dev.db"

# --- SECURITY ---
JWT_SECRET="change_me"

# --- SERVER ---
PORT=5000
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000,http://127.0.0.1:3000"

# --- EMAIL (Resend) ---
# Якщо ключ не заданий — сервер не зможе реально відправляти reset email.
RESEND_API_KEY="re_..."
# Вкажи верифікований sender (домени/адреси налаштовуються у Resend)
FROM_EMAIL="no-reply@yourdomain.com"

# --- AUTO.RIA VIN API ---
# Платний VIN API на developers.ria.com
AUTORIA_API_KEY="..."
AUTORIA_USER_ID="123456"
AUTORIA_LANG_ID=4
AUTORIA_PERIOD_DAYS=365

