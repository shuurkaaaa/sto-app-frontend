# --- DATABASE ---
DATABASE_URL="file:./dev.db"

# --- SECURITY ---
JWT_SECRET="change_me"

# --- SERVER ---
PORT=5000
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000,http://127.0.0.1:3000"

# --- EMAIL (Resend) ---
# Якщо RESEND_API_KEY не заданий — система буде працювати в DEV-режимі (показувати devResetUrl замість листа).
RESEND_API_KEY="re_..."
# Вкажи верифікований sender (домени/адреси налаштовуються у Resend)
FROM_EMAIL="no-reply@yourdomain.com"

